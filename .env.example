# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno del frontend (Next.js). Copiar a .env.local para dev.
# En Vercel se cargan en Settings → Environment Variables.
# OJO: Next "hornea" las NEXT_PUBLIC_* en el build — cambiar una variable en
# Vercel requiere REDEPLOY para que tome efecto.
# ─────────────────────────────────────────────────────────────────────────────

# URL del backend (sin barra final). Dev: http://localhost:5216
# Prod: https://api.<dominio-del-taller>
NEXT_PUBLIC_API_URL=http://localhost:5216

# Datos del taller — se muestran en emails/página de aprobación/pie de página
NEXT_PUBLIC_WORKSHOP_NAME=Nombre del Taller
NEXT_PUBLIC_WORKSHOP_PHONE=381XXXXXXX
NEXT_PUBLIC_WORKSHOP_WHATSAPP=549381XXXXXXX
NEXT_PUBLIC_WORKSHOP_EMAIL=taller@ejemplo.com
